package edu.infosys.lostFoundLocatorApplication.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import edu.infosys.lostFoundLocatorApplication.bean.User;
import edu.infosys.lostFoundLocatorApplication.dao.UserRepository;

@Service
public class UserService {

    @Autowired
    private UserRepository repository;

    public List<User> getAllStudents() {
        return repository.findByRole("Student");
    }

}